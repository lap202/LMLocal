<?xml version="1.0" encoding="utf-8"?>
<PackageManifest Version="2.0.0" xmlns="http://schemas.microsoft.com/developer/vsx-schema/2011" xmlns:d="http://schemas.microsoft.com/developer/vsx-schema-design/2011">
    <Metadata>
        <Identity Id="LMLocal.aa226645-3f53-489b-befb-2d37a76e7590" Version="1.3" Language="en-US" Publisher="Aleksandrs Kornevs" />
        <DisplayName>LM Local</DisplayName>
        <Description xml:space="preserve">Lightweight local AI chat for Visual Studio — interactive streaming responses, in-session chat, Markdown rendering, code highlighting, and clipboard support via LM Studio.</Description>
        <License>LICENSE.txt</License>
        <GettingStartedGuide>GettingStarted.txt</GettingStartedGuide>
        <Icon>Resources\logo.png</Icon>
        <Tags>LM Studio, LLM, Local AI, Chat</Tags>
    </Metadata>
    <Installation>
        <InstallationTarget Id="Microsoft.VisualStudio.Community" Version="[17.0, 19.0)">
            <ProductArchitecture>amd64</ProductArchitecture>
        </InstallationTarget>
    </Installation>
    <Dependencies>
        <Dependency Id="Microsoft.Framework.NDP" DisplayName="Microsoft .NET Framework" d:Source="Manual" Version="[4.5,)" />
    </Dependencies>
    <Prerequisites>
        <Prerequisite Id="Microsoft.VisualStudio.Component.CoreEditor" Version="[17.0,18.0)" DisplayName="Visual Studio core editor" />
    </Prerequisites>
    <Assets>
        <Asset Type="Microsoft.VisualStudio.VsPackage" d:Source="Project" d:ProjectName="%CurrentProject%" Path="|%CurrentProject%;PkgdefProjectOutputGroup|" />
    </Assets>
</PackageManifest>
